---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import type { SupportedEditorName } from '@a1st/aix-schema';
import {
   describeScopeSupport,
   describeTransition,
   getEditorById,
   getMigrationDescription,
   getMigrationHeadline,
   getMigrationRoute,
   getMigrationRows,
   listMigrationPairs,
   managedEditorFeatures,
} from '../../../lib/editor-support';
import { docsSidebar } from '../../../starlight-sidebar.js';

export function getStaticPaths() {
   return listMigrationPairs().map(({ from, to }) => ({
      params: { from, to },
      props: { from, to },
   }));
}

const { from, to } = Astro.props as {
   from: SupportedEditorName;
   to: SupportedEditorName;
};

const fromProfile = getEditorById(from),
      toProfile = getEditorById(to),
      rows = getMigrationRows(from, to),
      changedRows = rows.filter((row) => row.changeType !== 'same'),
      terminologyRows = changedRows.filter((row) => row.terminologyChanged),
      scopeRows = changedRows.filter((row) => row.scopeChanged),
      title = `How to migrate from ${fromProfile.name} to ${toProfile.name}`,
      description = getMigrationDescription(fromProfile, toProfile, rows);
---

<StarlightPage
   frontmatter={{ title, description, editUrl: false }}
   sidebar={docsSidebar}
>
   <p>
      When you sync from {fromProfile.name} to {toProfile.name}, aix imports {fromProfile.name}
      config into its bridge format and then installs the closest supported representation for{' '}
      {toProfile.name}.
   </p>

   <p>{getMigrationHeadline(rows)}</p>

   <h2>What changes</h2>
   <ul>
      {changedRows.map((row) => <li>{describeTransition(fromProfile, toProfile, row)}</li>)}
   </ul>

   <h2>Feature comparison</h2>
   <table>
      <caption>Feature-by-feature differences from {fromProfile.name} to {toProfile.name}.</caption>
      <thead>
         <tr>
            <th scope="col">Feature</th>
            <th scope="col">{fromProfile.name}</th>
            <th scope="col">{toProfile.name}</th>
            <th scope="col">Migration impact</th>
         </tr>
      </thead>
      <tbody>
         {managedEditorFeatures.map((featureDefinition) => {
            const row = rows.find((candidate) => candidate.feature.id === featureDefinition.id);

            if (!row) {
               return null;
            }

            return (
               <tr>
                  <th scope="row">{featureDefinition.label}</th>
                  <td>
                     <strong>{row.fromSupport.terminology}</strong>
                     <br />
                     {describeScopeSupport(row.fromSupport.project)}
                  </td>
                  <td>
                     <strong>{row.toSupport.terminology}</strong>
                     <br />
                     {describeScopeSupport(row.toSupport.project)}
                  </td>
                  <td>{describeTransition(fromProfile, toProfile, row)}</td>
               </tr>
            );
         })}
      </tbody>
   </table>

   {terminologyRows.length > 0 && (
      <>
         <h2>Terminology shifts</h2>
         <ul>
            {terminologyRows.map((row) => (
               <li>
                  {fromProfile.name} uses <strong>{row.fromSupport.terminology}</strong> for{' '}
                  {row.feature.label.toLowerCase()}, while {toProfile.name} uses{' '}
                  <strong>{row.toSupport.terminology}</strong>.
               </li>
            ))}
         </ul>
      </>
   )}

   {scopeRows.length > 0 && (
      <>
         <h2>Scope changes to plan for</h2>
         <ul>
            {scopeRows.map((row) => (
               <li>
                  <strong>{row.feature.label}:</strong> {fromProfile.name} project scope is{' '}
                  {describeScopeSupport(row.fromSupport.project)}. {toProfile.name} project scope is{' '}
                  {describeScopeSupport(row.toSupport.project)}.
               </li>
            ))}
         </ul>
      </>
   )}

   <h2>Recommended follow-up links</h2>
   <ul>
      <li>
         <a href={`/editors/supported-editors/#${fromProfile.id}`}>{fromProfile.name} support details</a>
      </li>
      <li>
         <a href={`/editors/supported-editors/#${toProfile.id}`}>{toProfile.name} support details</a>
      </li>
      <li>
         <a href={`/editors/editor-specific-notes/#${toProfile.id}`}>{toProfile.name} notes</a>
      </li>
      <li>
         <a href={getMigrationRoute(to, from)}>{toProfile.name} to {fromProfile.name}</a>
      </li>
   </ul>
</StarlightPage>
