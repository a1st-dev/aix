---
import type { EditorSupportStatus } from '@a1st/aix-schema';
import { getStatusDescription, getStatusLabel } from '../lib/editor-support';

const { compact = false, status } = Astro.props as {
   compact?: boolean;
   status: EditorSupportStatus;
};

const label = getStatusLabel(status),
      description = getStatusDescription(status);
---

<span
   aria-label={`${label}: ${description}`}
   class:list={[ 'support-status', `support-status--${status}`, compact && 'support-status--compact' ]}
   title={description}
>
   <span class="support-status__label">{label}</span>
</span>

<style>
   .support-status {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.2rem 0.55rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 999px;
      font-size: 0.78rem;
      line-height: 1;
      white-space: nowrap;
   }

   .support-status--compact {
      padding-inline: 0.45rem;
      font-size: 0.72rem;
   }

   .support-status--native {
      background: color-mix(in srgb, var(--sl-color-green-high) 10%, transparent);
      border-color: color-mix(in srgb, var(--sl-color-green) 30%, var(--sl-color-gray-5));
   }

   .support-status--shim {
      background: color-mix(in srgb, var(--sl-color-orange-high) 10%, transparent);
      border-color: color-mix(in srgb, var(--sl-color-orange) 30%, var(--sl-color-gray-5));
   }

   .support-status--unsupported {
      background: color-mix(in srgb, var(--sl-color-red-high) 8%, transparent);
      border-color: color-mix(in srgb, var(--sl-color-red) 30%, var(--sl-color-gray-5));
   }
</style>
