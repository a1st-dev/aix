{
   "name": "@a1st/aix-core",
   "version": "0.2.0",
   "description": "Core utilities for aix configuration loading and management",
   "keywords": [
      "ai-agent",
      "ai-config",
      "config-loader",
      "mcp",
      "model-context-protocol"
   ],
   "repository": {
      "type": "git",
      "url": "https://github.com/a1st-dev/aix.git",
      "directory": "packages/core"
   },
   "files": [
      "dist"
   ],
   "type": "module",
   "main": "./dist/index.js",
   "browser": {
      "./src/runtime/node.ts": "./src/runtime/browser-dummy.ts",
      "./dist/runtime/node.js": "./dist/runtime/browser-dummy.js"
   },
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js"
      }
   },
   "publishConfig": {
      "access": "public",
      "registry": "https://registry.npmjs.org/"
   },
   "scripts": {
      "build": "tsc -p tsconfig.build.json",
      "test": "vitest run",
      "test:watch": "vitest"
   },
   "dependencies": {
      "@a1st/aix-schema": "*",
      "@astrojs/starlight": "0.39.2",
      "@astrojs/vercel": "10.0.6",
      "@yeskunall/astro-umami": "0.0.8",
      "astro": "6.3.1",
      "c12": "^4.0.0-beta.5",
      "confbox": "0.2.2",
      "defu": "^6.1.7",
      "detect-indent": "7.0.2",
      "giget": "^3.2.0",
      "is-in-ci": "2.0.0",
      "nypm": "0.3.12",
      "p-map": "7.0.4",
      "pathe": "1.1.2",
      "vitest": "4.1.5",
      "yaml": "^2.8.4"
   }
}
